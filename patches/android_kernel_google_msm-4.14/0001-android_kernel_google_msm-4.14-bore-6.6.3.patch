+    { }
+};
+static int __init sched_bore_sysctl_init(void) {
+    register_sysctl("kernel", sched_bore_sysctls);
+    return 0;
+}
+late_initcall(sched_bore_sysctl_init);
+#endif // CONFIG_SYSCTL
+#endif /* CONFIG_SCHED_BORE */
