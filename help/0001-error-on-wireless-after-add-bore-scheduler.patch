From e70ca793efbe78d57446d54aeb725f1043748126 Mon Sep 17 00:00:00 2001
From: Salman Wahib <sxlmnwb.dev@gmail.com>
Date: Thu, 11 Jun 2026 15:12:42 +0700
Subject: [PATCH 3/6] defconfig(gki): restructure crypto and enable wireless
 TLS subsystems

- this affect to fix bug after add bore scheduler for android

Signed-off-by: Salman Wahib <sxlmnwb.dev@gmail.com>
---
 arch/arm64/configs/gki_defconfig | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/arch/arm64/configs/gki_defconfig b/arch/arm64/configs/gki_defconfig
index 17d902a19..8c5b02262 100644
--- a/arch/arm64/configs/gki_defconfig
+++ b/arch/arm64/configs/gki_defconfig
@@ -748,6 +748,9 @@ CONFIG_CRYPTO_SHA2_ARM64_CE=y
 CONFIG_CRYPTO_SHA512_ARM64_CE=y
 CONFIG_CRYPTO_POLYVAL_ARM64_CE=y
 CONFIG_CRYPTO_AES_ARM64_CE_BLK=y
+CONFIG_CRYPTO_RSA=y
+CONFIG_CRYPTO_GCM=y
+CONFIG_CRYPTO_SHA256=y
 CONFIG_TRACE_MMIO_ACCESS=y
 CONFIG_CRC_CCITT=y
 CONFIG_XZ_DEC=y
@@ -800,3 +803,17 @@ CONFIG_LTO_CLANG_THIN=y
 # BORE Burst-Oriented Response Enhancer
 CONFIG_SCHED_BORE=y
 CONFIG_SCHED_DEBUG=y
+
+# Wireless and dependency
+CONFIG_WIRELESS=y
+CONFIG_CFG80211=y
+CONFIG_MAC80211=y
+CONFIG_ASYMMETRIC_KEY_TYPE=y
+CONFIG_ASYMMETRIC_PUBLIC_KEY_SUBTYPE=y
+CONFIG_X509_CERTIFICATE_PARSER=y
+CONFIG_PKCS7_MESSAGE_PARSER=y
+CONFIG_ASN1=y
+CONFIG_MPILIB=y
+CONFIG_OID_REGISTRY=y
+CONFIG_SYSTEM_DATA_VERIFICATION=y
+CONFIG_TLS=y
--
2.54.0

